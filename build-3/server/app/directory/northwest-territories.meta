{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/directory/layout,_N_T_/directory/[region]/layout,_N_T_/directory/[region]/page,_N_T_/directory/northwest-territories"
  },
  "segmentPaths": [
